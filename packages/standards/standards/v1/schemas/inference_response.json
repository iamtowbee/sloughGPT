{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sloughgpt.local/standards/v1/inference_response.json",
  "title": "SloughGPT Inference Response v1",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "trace_id": { "type": "string" },
    "model_id": { "type": "string" },
    "model_version": {
      "type": "string",
      "description": "Registry revision, git SHA, or artifact hash."
    },
    "task_type": { "type": "string" },
    "mode": { "type": "string" },
    "output": {
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "structured": { "type": "object", "additionalProperties": true }
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 }
      }
    },
    "safety_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "severity"],
        "properties": {
          "rule_id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "warn", "block"]
          },
          "message": { "type": "string" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": { "type": "string" },
          "uri": { "type": "string" },
          "snippet": { "type": "string" },
          "span": { "type": "string" }
        }
      }
    }
  },
  "required": ["trace_id", "model_id", "task_type"]
}
