# Lightweight model/API image — same layout as Dockerfile; trim pip extras here if needed.
FROM python:3.11-slim

LABEL maintainer="SloughGPT"
LABEL description="SloughGPT model server (monorepo layout)"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    SLOUGHGPT_ENV="production" \
    SLOUGHGPT_LOG_LEVEL="INFO"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

COPY apps/api/server/requirements.txt /tmp/requirements-api.txt
RUN pip install --no-cache-dir -r /tmp/requirements-api.txt \
    && pip install --no-cache-dir scipy psutil

COPY apps/api/server /app/apps/api/server
COPY packages/core-py /app/packages/core-py
COPY packages/sdk-py/sloughgpt_sdk /app/packages/sdk-py/sloughgpt_sdk
COPY pyproject.toml README.md LICENSE /app/

RUN mkdir -p /app/data /app/logs /app/cache /app/models /app/datasets

ENV CUDA_VISIBLE_DEVICES=""

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["python", "/app/apps/api/server/main.py"]
