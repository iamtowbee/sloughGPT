FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    SLOUGHGPT_ENV="development" \
    SLOUGHGPT_LOG_LEVEL="DEBUG"

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    vim \
    htop \
    procps \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && \
    pip install torch --index-url https://download.pytorch.org/whl/cpu

COPY apps/api/server/requirements.txt /tmp/requirements-api.txt
RUN pip install -r /tmp/requirements-api.txt

RUN pip install transformers accelerate bitsandbytes scipy pytest pytest-asyncio pytest-cov ruff black mypy ipython psutil

COPY apps/api/server /app/apps/api/server
COPY packages/core-py /app/packages/core-py
COPY packages/sdk-py/sloughgpt_sdk /app/packages/sdk-py/sloughgpt_sdk
COPY pyproject.toml README.md LICENSE /app/

RUN mkdir -p /app/models /app/datasets /app/data /app/logs /app/checkpoints

WORKDIR /app/apps/api/server

EXPOSE 8000 5678

CMD ["uvicorn", "main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
