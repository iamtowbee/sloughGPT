# SloughGPT Configuration

# API Settings
SLOUGHGPT_API_URL=http://localhost:8000
SLOUGHGPT_API_KEY=

# Model Settings
SLOUGHGPT_DEFAULT_MODEL=gpt2
SLOUGHGPT_MODEL_CACHE_DIR=./models

# Training Settings
SLOUGHGPT_DEFAULT_EPOCHS=3
SLOUGHGPT_DEFAULT_BATCH_SIZE=8
SLOUGHGPT_DEFAULT_LR=0.00001

# Output Settings
SLOUGHGPT_OUTPUT_FORMAT=json
SLOUGHGPT_VERBOSE=false
