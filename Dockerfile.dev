# SloughGPT Development Dockerfile
# Optimized for development with hot reloading

FROM python:3.10-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    SLAUGHGPT_ENV="development" \
    SLAUGHGPT_LOG_LEVEL="DEBUG"

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    vim \
    htop \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install PyTorch CPU
RUN pip install --upgrade pip && \
    pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

# Install core dependencies
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Install ML dependencies
RUN pip install transformers accelerate bitsandbytes scipy

# Install development tools
RUN pip install pytest pytest-asyncio pytest-cov ruff black mypy ipython

# Copy application
COPY . .

# Create directories
RUN mkdir -p /app/models /app/datasets /app/data /app/logs /app/checkpoints

EXPOSE 8000 5678

# Development command
CMD ["uvicorn", "domains.ui.api_server:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
