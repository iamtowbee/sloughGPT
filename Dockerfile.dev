FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    SLAUGHGPT_ENV="development" \
    SLAUGHGPT_LOG_LEVEL="DEBUG"

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    vim \
    htop \
    procps \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && \
    pip install torch --index-url https://download.pytorch.org/whl/cpu

COPY server/requirements.txt ./
RUN pip install -r requirements.txt

RUN pip install transformers accelerate bitsandbytes scipy pytest pytest-asyncio pytest-cov ruff black mypy ipython

COPY server/ ./server/
COPY sloughgpt_sdk/ ./sloughgpt_sdk/
COPY training/ ./training/
COPY inference/ ./inference/
COPY monitoring/ ./monitoring/
COPY evaluation/ ./evaluation/
COPY experiments/ ./experiments/
COPY pyproject.toml .
COPY README.md .
COPY LICENSE .

RUN mkdir -p /app/models /app/datasets /app/data /app/logs /app/checkpoints

EXPOSE 8000 5678

CMD ["uvicorn", "server.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
